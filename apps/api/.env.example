# Comma-separated origins allowed by CORS (frontend dev server, etc.)
CORS_ALLOW_ORIGINS=http://localhost:3000

# Where pipeline artifacts are written. Resolved relative to repo root if not absolute.
DATA_DIR=../../data

# ---------------------------------------------------------------------------
# LLM provider configuration.
# Adapter pattern -- product code never references a provider directly.
# Set LLM_PROVIDER and the matching variables below.
# Never commit real keys -- this file is documentation; .env is gitignored.
# ---------------------------------------------------------------------------

# One of: seed | mock
LLM_PROVIDER=seed

# ByteDance Seed (AIGC) -- primary provider for this project.
# Required when LLM_PROVIDER=seed:
SEED_API_KEY=
SEED_MODEL=
SEED_ENDPOINT_ID=

# Optional: override the default Seed base URL.
# Defaults to https://ark.cn-beijing.volces.com/api/v3 (Volcano Ark cn-beijing).
# Only set this if your deployment uses a different region or host.
SEED_API_BASE_URL=
